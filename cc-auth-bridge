#!/usr/bin/env bash
set -euo pipefail

# cc-auth-bridge — Beam Claude Code OAuth tokens to headless machines via LocalSend
# https://github.com/localsend/localsend

readonly VERSION="1.0.0"
readonly CREDS_DIR="$HOME/.claude"
readonly CREDS_FILE="$CREDS_DIR/.credentials.json"
readonly DEFAULT_PORT=53317

# --- Color helpers ---

_setup_colors() {
    if [[ "${NO_COLOR:-}" != "" ]] || [[ "${TERM:-dumb}" == "dumb" ]] || ! command -v tput &>/dev/null; then
        RED="" GREEN="" YELLOW="" BLUE="" BOLD="" RESET=""
    else
        RED=$(tput setaf 1)    GREEN=$(tput setaf 2)
        YELLOW=$(tput setaf 3) BLUE=$(tput setaf 4)
        BOLD=$(tput bold)      RESET=$(tput sgr0)
    fi
}
_setup_colors

log_info()    { printf '%s[info]%s %s\n'    "$BLUE"   "$RESET" "$*"; }
log_warn()    { printf '%s[warn]%s %s\n'    "$YELLOW" "$RESET" "$*" >&2; }
log_error()   { printf '%s[error]%s %s\n'   "$RED"    "$RESET" "$*" >&2; }
log_success() { printf '%s[ok]%s %s\n'      "$GREEN"  "$RESET" "$*"; }

# --- Cleanup trap ---

TMPFILES=()
cleanup() {
    for f in "${TMPFILES[@]}"; do
        rm -f "$f" 2>/dev/null || true
    done
}
trap cleanup EXIT

mktmpfile() {
    local f
    f=$(mktemp "${TMPDIR:-/tmp}/cc-auth-bridge.XXXXXX")
    TMPFILES+=("$f")
    echo "$f"
}

# --- Utility functions ---

detect_os() {
    local uname_out
    uname_out=$(uname -s)
    case "$uname_out" in
        Darwin) echo "darwin" ;;
        Linux)  echo "linux" ;;
        *)      log_error "Unsupported OS: $uname_out"; exit 1 ;;
    esac
}

detect_arch() {
    local machine
    machine=$(uname -m)
    case "$machine" in
        x86_64|amd64)       echo "amd64" ;;
        aarch64|arm64)      echo "arm64" ;;
        armv7l|armhf)       echo "armv7" ;;
        *)                  echo "$machine" ;;
    esac
}

get_local_ip() {
    local os
    os=$(detect_os)
    if [[ "$os" == "darwin" ]]; then
        # Try common interfaces in order
        for iface in en0 en1 en2; do
            local ip
            ip=$(ipconfig getifaddr "$iface" 2>/dev/null || true)
            if [[ -n "$ip" ]]; then
                echo "$ip"
                return
            fi
        done
        log_warn "Could not detect local IP"
        echo "unknown"
    else
        # Linux
        local ip
        ip=$(hostname -I 2>/dev/null | awk '{print $1}')
        if [[ -n "$ip" ]]; then
            echo "$ip"
        else
            log_warn "Could not detect local IP"
            echo "unknown"
        fi
    fi
}

discover_devices() {
    local port="$1"
    local my_ip
    my_ip=$(get_local_ip)

    if [[ "$my_ip" == "unknown" ]]; then
        log_error "Cannot discover devices: local IP unknown"
        return 1
    fi

    # Derive /24 subnet base
    local subnet_base
    subnet_base=$(echo "$my_ip" | sed 's/\.[0-9]*$//')

    log_info "Scanning ${subnet_base}.0/24 for LocalSend listeners on port ${port}..."

    local tmpdir
    tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/cc-auth-scan.XXXXXX")
    TMPFILES+=("$tmpdir")

    # Parallel scan: hit the LocalSend v2 info endpoint on each IP
    # Use HTTPS with --insecure since LocalSend uses self-signed certs
    local pids=()
    for i in $(seq 1 254); do
        local ip="${subnet_base}.${i}"
        # Skip our own IP
        [[ "$ip" == "$my_ip" ]] && continue
        (
            local resp
            resp=$(curl -skf --connect-timeout 1 --max-time 2 \
                "https://${ip}:${port}/api/localsend/v2/info" 2>/dev/null) || exit 1
            # Validate it looks like a LocalSend response
            if echo "$resp" | jq -e '.alias' &>/dev/null 2>&1; then
                local alias
                alias=$(echo "$resp" | jq -r '.alias // "unknown"')
                echo "${ip}|${alias}" > "$tmpdir/${i}"
            fi
        ) &
        pids+=($!)
        # Limit concurrency to avoid fd exhaustion
        if (( ${#pids[@]} >= 50 )); then
            wait "${pids[0]}" 2>/dev/null || true
            pids=("${pids[@]:1}")
        fi
    done
    # Wait for all remaining
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Collect results
    local devices=()
    for f in "$tmpdir"/*; do
        [[ -f "$f" ]] || continue
        devices+=("$(cat "$f")")
    done

    if [[ ${#devices[@]} -eq 0 ]]; then
        return 1
    fi

    # Print and return
    printf '%s\n' "${devices[@]}"
}

select_device() {
    local port="$1"

    local devices_raw
    devices_raw=$(discover_devices "$port") || {
        log_warn "No LocalSend devices found on the network."
        echo ""
        read -rp "Enter the target machine's IP address manually: " manual_ip
        if [[ -z "$manual_ip" ]]; then
            log_error "No target IP provided."
            exit 1
        fi
        echo "$manual_ip"
        return
    }

    # Parse into arrays
    local ips=() aliases=()
    while IFS='|' read -r ip alias; do
        ips+=("$ip")
        aliases+=("$alias")
    done <<< "$devices_raw"

    if [[ ${#ips[@]} -eq 1 ]]; then
        log_success "Found 1 device: ${aliases[0]} (${ips[0]})"
        read -rp "Send to this device? [Y/n] " answer
        if [[ "${answer,,}" == "n" ]]; then
            read -rp "Enter the target machine's IP address: " manual_ip
            echo "$manual_ip"
            return
        fi
        echo "${ips[0]}"
        return
    fi

    echo ""
    log_info "Found ${#ips[@]} LocalSend devices:"
    echo ""
    for i in "${!ips[@]}"; do
        printf '  %s[%d]%s  %s (%s)\n' "$BOLD" $((i + 1)) "$RESET" "${aliases[$i]}" "${ips[$i]}"
    done
    echo ""
    read -rp "Select device [1-${#ips[@]}]: " choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#ips[@]} )); then
        echo "${ips[$((choice - 1))]}"
    else
        log_error "Invalid selection."
        exit 1
    fi
}

LOCALSEND_BIN=""

find_localsend_cli() {
    # Check PATH candidates (official + localsend-go)
    for candidate in localsend_app localsend-cli localsend localsend-go; do
        if command -v "$candidate" &>/dev/null; then
            LOCALSEND_BIN="$candidate"
            return 0
        fi
    done
    # Check common manual install location
    if [[ -x "$HOME/.local/bin/localsend-go" ]]; then
        LOCALSEND_BIN="$HOME/.local/bin/localsend-go"
        return 0
    fi
    return 1
}

# Returns "localsend-go" if we installed/found the Go CLI, empty otherwise
LOCALSEND_VARIANT=""

detect_localsend_variant() {
    if [[ "$LOCALSEND_BIN" == *localsend-go* ]]; then
        LOCALSEND_VARIANT="localsend-go"
    else
        LOCALSEND_VARIANT="official"
    fi
}

check_dependencies() {
    local missing=0
    local os
    os=$(detect_os)

    if ! command -v claude &>/dev/null; then
        log_error "'claude' CLI not found in PATH"
        echo "  Install: npm install -g @anthropic-ai/claude-code"
        missing=1
    fi

    if ! command -v jq &>/dev/null; then
        log_error "'jq' not found in PATH"
        if [[ "$os" == "darwin" ]]; then
            echo "  Install: brew install jq"
        else
            echo "  Install: sudo apt-get install jq"
        fi
        missing=1
    fi

    if ! find_localsend_cli; then
        log_error "LocalSend CLI not found in PATH"
        echo "  Looked for: localsend_app, localsend-cli, localsend, localsend-go"
        if [[ "$os" == "darwin" ]]; then
            echo "  Install: brew install localsend"
        else
            local arch
            arch=$(detect_arch)
            if [[ "$arch" == "arm64" || "$arch" == "armv7" ]]; then
                echo "  ARM detected — will install localsend-go (headless-friendly Go CLI)"
            else
                echo "  Install: see https://github.com/localsend/localsend#install"
            fi
        fi
        echo ""
        read -rp "Attempt automatic install? [y/N] " answer
        if [[ "${answer,,}" == "y" ]]; then
            install_localsend
        else
            missing=1
        fi
    else
        detect_localsend_variant
        if [[ "$LOCALSEND_VARIANT" == "localsend-go" ]]; then
            log_info "Using localsend-go CLI: $LOCALSEND_BIN"
        fi
    fi

    if [[ $missing -ne 0 ]]; then
        log_error "Missing dependencies. Install them and retry."
        exit 1
    fi
}

install_localsend() {
    local os arch
    os=$(detect_os)
    arch=$(detect_arch)

    if [[ "$os" == "darwin" ]]; then
        log_info "Installing LocalSend via Homebrew..."
        if ! command -v brew &>/dev/null; then
            log_error "Homebrew not found. Install LocalSend manually."
            exit 1
        fi
        brew install localsend
    elif [[ "$os" == "linux" ]]; then
        # Decide strategy: ARM or headless → localsend-go, x86_64 with desktop → official .deb
        local use_go=false

        if [[ "$arch" == "arm64" || "$arch" == "armv7" ]]; then
            use_go=true
            log_info "ARM architecture detected ($arch) — using localsend-go"
        elif [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
            use_go=true
            log_info "Headless environment detected — using localsend-go (no GUI needed)"
        fi

        if [[ "$use_go" == true ]]; then
            install_localsend_go
        else
            install_localsend_official_deb
        fi
    fi

    if ! find_localsend_cli; then
        log_error "LocalSend installed but CLI binary not found in PATH."
        log_error "You may need to add it to your PATH or restart your shell."
        exit 1
    fi
    detect_localsend_variant
    log_success "LocalSend CLI found: $LOCALSEND_BIN"
}

install_localsend_go() {
    local arch
    arch=$(detect_arch)

    # Map to localsend-go release naming
    local go_arch=""
    case "$arch" in
        amd64)  go_arch="amd64" ;;
        arm64)  go_arch="arm64" ;;
        armv7)  go_arch="arm" ;;
        *)      log_error "Unsupported architecture for localsend-go: $arch"; exit 1 ;;
    esac

    log_info "Fetching latest localsend-go release..."
    local release_url="https://api.github.com/repos/meowrain/localsend-go/releases/latest"
    local release_json
    release_json=$(curl -fsSL "$release_url" 2>/dev/null)

    if [[ -z "$release_json" ]]; then
        log_error "Could not fetch localsend-go releases from GitHub"
        log_error "Install manually: https://github.com/meowrain/localsend-go/releases"
        exit 1
    fi

    # Find the linux-arm64 or linux-amd64 binary asset
    local download_url
    download_url=$(echo "$release_json" | jq -r \
        --arg pattern "linux-${go_arch}" \
        '[.assets[] | select(.name | test($pattern; "i")) | select(.name | test("\\.(tar\\.gz|zip)$") | not)] | .[0].browser_download_url // empty')

    # Fallback: try tar.gz if no bare binary
    if [[ -z "$download_url" ]]; then
        download_url=$(echo "$release_json" | jq -r \
            --arg pattern "linux-${go_arch}" \
            '[.assets[] | select(.name | test($pattern; "i"))] | .[0].browser_download_url // empty')
    fi

    if [[ -z "$download_url" ]]; then
        log_error "Could not find localsend-go binary for linux-${go_arch}"
        log_error "Available assets:"
        echo "$release_json" | jq -r '.assets[].name' >&2
        log_error "Install manually: https://github.com/meowrain/localsend-go/releases"
        exit 1
    fi

    local filename
    filename=$(basename "$download_url")
    log_info "Downloading $filename ..."

    local install_dir="$HOME/.local/bin"
    mkdir -p "$install_dir"

    local tmpf
    tmpf=$(mktmpfile)
    curl -fsSL -o "$tmpf" "$download_url"

    if [[ "$filename" == *.tar.gz ]]; then
        local tmpdir
        tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/localsend-go-extract.XXXXXX")
        TMPFILES+=("$tmpdir")
        tar -xzf "$tmpf" -C "$tmpdir"
        # Find the binary inside
        local bin_found=""
        for f in "$tmpdir"/localsend-go* "$tmpdir"/*/localsend-go*; do
            if [[ -f "$f" && ! "$f" == *.tar.gz ]]; then
                bin_found="$f"
                break
            fi
        done
        if [[ -z "$bin_found" ]]; then
            log_error "Could not find localsend-go binary in archive"
            ls -la "$tmpdir" >&2
            exit 1
        fi
        cp "$bin_found" "$install_dir/localsend-go"
    elif [[ "$filename" == *.zip ]]; then
        local tmpdir
        tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/localsend-go-extract.XXXXXX")
        TMPFILES+=("$tmpdir")
        unzip -q "$tmpf" -d "$tmpdir"
        local bin_found=""
        for f in "$tmpdir"/localsend-go* "$tmpdir"/*/localsend-go*; do
            if [[ -f "$f" && ! "$f" == *.zip ]]; then
                bin_found="$f"
                break
            fi
        done
        if [[ -z "$bin_found" ]]; then
            log_error "Could not find localsend-go binary in archive"
            exit 1
        fi
        cp "$bin_found" "$install_dir/localsend-go"
    else
        # Bare binary
        cp "$tmpf" "$install_dir/localsend-go"
    fi

    chmod +x "$install_dir/localsend-go"
    log_success "Installed localsend-go to $install_dir/localsend-go"

    # Ensure ~/.local/bin is in PATH for this session
    if ! echo "$PATH" | tr ':' '\n' | grep -qx "$install_dir"; then
        export PATH="$install_dir:$PATH"
        log_warn "$install_dir is not in your PATH. Added for this session."
        log_warn "Add permanently: export PATH=\"$install_dir:\$PATH\" in your shell rc"
    fi

    # Set network capabilities for device discovery (optional, non-fatal)
    if command -v setcap &>/dev/null; then
        log_info "Setting network capabilities for device discovery..."
        sudo setcap cap_net_raw=+ep "$install_dir/localsend-go" 2>/dev/null || \
            log_warn "Could not set cap_net_raw (device discovery may not work, but direct IP send/receive will)"
    fi
}

install_localsend_official_deb() {
    log_info "Installing official LocalSend .deb..."
    if ! command -v apt-get &>/dev/null; then
        log_error "apt-get not found. Cannot install .deb package."
        log_info "Falling back to localsend-go..."
        install_localsend_go
        return
    fi

    local release_url latest_tag deb_url tmpf
    release_url="https://api.github.com/repos/localsend/localsend/releases/latest"
    latest_tag=$(curl -fsSL "$release_url" | jq -r '.tag_name')
    if [[ -z "$latest_tag" || "$latest_tag" == "null" ]]; then
        log_error "Could not fetch latest LocalSend release. Falling back to localsend-go..."
        install_localsend_go
        return
    fi
    local ver="${latest_tag#v}"
    deb_url="https://github.com/localsend/localsend/releases/download/${latest_tag}/LocalSend-${ver}-linux-x86-64.deb"
    tmpf=$(mktmpfile)
    log_info "Downloading $deb_url ..."
    if ! curl -fsSL -o "$tmpf" "$deb_url"; then
        log_error "Download failed. Falling back to localsend-go..."
        install_localsend_go
        return
    fi
    sudo dpkg -i "$tmpf" || sudo apt-get install -f -y
}

extract_token() {
    if [[ ! -f "$CREDS_FILE" ]]; then
        log_error "Credentials file not found: $CREDS_FILE"
        return 1
    fi

    local token
    token=$(jq -r '
        # Try common key patterns
        if .claudeAiOauth then .claudeAiOauth.accessToken
        elif .oauth_token then .oauth_token
        elif .token then .token
        else (to_entries | map(select(.value | type == "string" and startswith("sk-ant-oat01-"))) | .[0].value // empty)
        end
    ' "$CREDS_FILE" 2>/dev/null || true)

    if [[ -z "$token" ]]; then
        # Fallback: grep for the token pattern
        token=$(grep -oE 'sk-ant-oat01-[A-Za-z0-9_-]+' "$CREDS_FILE" 2>/dev/null | head -1 || true)
    fi

    if [[ -z "$token" ]]; then
        log_error "Could not extract OAuth token from $CREDS_FILE"
        log_error "Expected token matching pattern: sk-ant-oat01-*"
        return 1
    fi

    if [[ ! "$token" =~ ^sk-ant-oat01- ]]; then
        log_warn "Token does not match expected pattern (sk-ant-oat01-*). Proceeding anyway."
    fi

    echo "$token"
}

backup_credentials() {
    if [[ -f "$CREDS_FILE" ]]; then
        local ts backup
        ts=$(date +%Y%m%d%H%M%S)
        backup="${CREDS_FILE}.bak.${ts}"
        cp "$CREDS_FILE" "$backup"
        log_info "Backed up existing credentials to $backup"
    fi
}

write_credentials() {
    local token="$1"
    mkdir -p "$CREDS_DIR"

    # If existing creds file has structure, try to preserve it
    if [[ -f "$CREDS_FILE" ]] && jq -e '.claudeAiOauth' "$CREDS_FILE" &>/dev/null; then
        # Update the existing structure
        local tmpf
        tmpf=$(mktmpfile)
        jq --arg tok "$token" '.claudeAiOauth.accessToken = $tok' "$CREDS_FILE" > "$tmpf"
        mv "$tmpf" "$CREDS_FILE"
    else
        # Write a simple credentials file
        cat > "$CREDS_FILE" <<CREDS_EOF
{
  "claudeAiOauth": {
    "accessToken": "$token"
  }
}
CREDS_EOF
    fi

    chmod 600 "$CREDS_FILE"
    log_success "Credentials written to $CREDS_FILE (mode 0600)"
}

inject_env_var() {
    local token="$1"
    local start_marker="# --- cc-auth-bridge START ---"
    local end_marker="# --- cc-auth-bridge END ---"
    local export_line="export CLAUDE_OAUTH_TOKEN=\"$token\""
    local block
    block=$(printf '%s\n%s\n%s' "$start_marker" "$export_line" "$end_marker")

    local rc_files=()
    if [[ -f "$HOME/.bashrc" ]]; then rc_files+=("$HOME/.bashrc"); fi
    if [[ -f "$HOME/.zshrc" ]]; then rc_files+=("$HOME/.zshrc"); fi

    # If no rc files exist, create .bashrc
    if [[ ${#rc_files[@]} -eq 0 ]]; then
        rc_files=("$HOME/.bashrc")
        touch "$HOME/.bashrc"
    fi

    for rcfile in "${rc_files[@]}"; do
        if grep -qF "$start_marker" "$rcfile" 2>/dev/null; then
            # Replace existing block
            local tmpf
            tmpf=$(mktmpfile)
            awk -v start="$start_marker" -v end="$end_marker" -v block="$block" '
                $0 == start { skip=1; print block; next }
                $0 == end   { skip=0; next }
                !skip       { print }
            ' "$rcfile" > "$tmpf"
            mv "$tmpf" "$rcfile"
            log_info "Updated token block in $rcfile"
        else
            # Append
            printf '\n%s\n' "$block" >> "$rcfile"
            log_info "Appended token block to $rcfile"
        fi
    done
}

verify_auth() {
    log_info "Verifying authentication with Claude..."
    local output
    if output=$(claude -p "say hi" --output-format json 2>&1); then
        if echo "$output" | jq -e '.error' &>/dev/null 2>&1; then
            local err
            err=$(echo "$output" | jq -r '.error' 2>/dev/null || echo "$output")
            log_error "Auth verification failed: $err"
            return 1
        fi
        log_success "Authentication verified — Claude is working!"
        return 0
    else
        log_error "Auth verification failed. 'claude' command returned non-zero."
        log_error "Output: $output"
        return 1
    fi
}

warn_api_key() {
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        echo ""
        printf '%s%s========================================%s\n' "$BOLD" "$YELLOW" "$RESET"
        printf '%s%s  WARNING: ANTHROPIC_API_KEY is set!%s\n'    "$BOLD" "$YELLOW" "$RESET"
        printf '%s%s========================================%s\n' "$BOLD" "$YELLOW" "$RESET"
        echo ""
        log_warn "Claude Code may use the API key instead of the OAuth token."
        log_warn "If you want to use the subscription (OAuth) auth, unset it:"
        echo "    unset ANTHROPIC_API_KEY"
        echo ""
    fi
}

# --- LocalSend variant abstraction ---
# localsend-go has different CLI syntax than the official app:
#   receive: no --destination flag, saves to ./uploads/ relative to cwd
#   send:    no --target flag, uses interactive device picker
#   --port must come BEFORE the subcommand

do_localsend_receive() {
    local port="$1"
    local recv_dir="$2"

    if [[ "$LOCALSEND_VARIANT" == "localsend-go" ]]; then
        # localsend-go saves to ./uploads/ relative to cwd, no dest flag
        # We cd to recv_dir so uploads/ lands inside it
        log_info "Using localsend-go receive (auto-accept enabled)..."
        (cd "$recv_dir" && "$LOCALSEND_BIN" --port="$port" receive)
        # Move files from uploads/ subdirectory up
        if [[ -d "$recv_dir/uploads" ]]; then
            mv "$recv_dir/uploads"/* "$recv_dir/" 2>/dev/null || true
            rmdir "$recv_dir/uploads" 2>/dev/null || true
        fi
    else
        "$LOCALSEND_BIN" receive --port "$port" --destination "$recv_dir"
    fi
}

do_localsend_send() {
    local port="$1"
    local target="$2"
    local file="$3"

    if [[ "$LOCALSEND_VARIANT" == "localsend-go" ]]; then
        # localsend-go uses interactive device picker — tell user which to select
        log_info "localsend-go will show discovered devices. Select the one matching: $target"
        if [[ "$port" != "$DEFAULT_PORT" ]]; then
            log_warn "localsend-go hardcodes remote port $DEFAULT_PORT when sending."
        fi
        echo ""
        "$LOCALSEND_BIN" --port="$port" send "$file"
    else
        "$LOCALSEND_BIN" send --port "$port" --destination "$target" --file "$file"
    fi
}

# --- Subcommands ---

cmd_listen() {
    local port="$DEFAULT_PORT"
    local no_verify=false
    local dry_run=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)     port="$2"; shift 2 ;;
            --no-verify) no_verify=true; shift ;;
            --dry-run)  dry_run=true; shift ;;
            -h|--help)  usage_listen; exit 0 ;;
            *)          log_error "Unknown flag: $1"; usage_listen; exit 1 ;;
        esac
    done

    check_dependencies
    warn_api_key

    local ip
    ip=$(get_local_ip)
    echo ""
    log_info "This machine's local IP: ${BOLD}${ip}${RESET}"
    log_info "Listening for incoming token on port ${BOLD}${port}${RESET}..."
    echo ""
    echo "  On the authenticated machine, run:"
    echo "    ${BOLD}cc-auth-bridge provide${RESET}"
    echo ""
    echo "  It will auto-discover this device, or you can specify:"
    echo "    ${BOLD}cc-auth-bridge provide --target $ip${RESET}"
    echo ""

    # Receive file via LocalSend
    local recv_dir
    recv_dir=$(mktemp -d "${TMPDIR:-/tmp}/cc-auth-recv.XXXXXX")
    TMPFILES+=("$recv_dir")

    log_info "Waiting for token transfer via LocalSend..."
    if ! do_localsend_receive "$port" "$recv_dir"; then
        log_error "LocalSend receive failed"
        exit 1
    fi

    # Find the received JSON file
    local json_file=""
    for f in "$recv_dir"/*.json; do
        if [[ -f "$f" ]]; then
            json_file="$f"
            break
        fi
    done

    if [[ -z "$json_file" ]]; then
        log_error "No JSON file received. Expected a .json file from LocalSend."
        log_error "Files in receive directory:"
        ls -la "$recv_dir" >&2
        exit 1
    fi

    log_info "Received file: $json_file"

    # Parse and validate
    local token
    token=$(jq -r '.claude_code_oauth_token // empty' "$json_file" 2>/dev/null || true)

    if [[ -z "$token" ]]; then
        log_error "Received file does not contain 'claude_code_oauth_token' field."
        log_error "File contents:"
        cat "$json_file" >&2
        exit 1
    fi

    if [[ ! "$token" =~ ^sk-ant-oat01- ]]; then
        log_warn "Token does not match expected format (sk-ant-oat01-*)"
    fi

    local source_host generated_at
    source_host=$(jq -r '.source_host // "unknown"' "$json_file" 2>/dev/null)
    generated_at=$(jq -r '.generated_at // "unknown"' "$json_file" 2>/dev/null)
    log_info "Token from host: $source_host (generated: $generated_at)"

    if [[ "$dry_run" == true ]]; then
        echo ""
        log_info "[DRY RUN] Would write credentials to $CREDS_FILE"
        log_info "[DRY RUN] Would inject env var into shell rc files"
        log_info "[DRY RUN] Token: ${token:0:20}..."
        exit 0
    fi

    # Write credentials
    backup_credentials
    write_credentials "$token"
    inject_env_var "$token"

    # Verify
    if [[ "$no_verify" == false ]]; then
        echo ""
        if verify_auth; then
            echo ""
            log_success "All done! Claude Code is authenticated on this machine."
        else
            echo ""
            log_warn "Verification failed. The token was written, but Claude may not be working."
            log_warn "Try running: claude auth login"
            exit 1
        fi
    else
        echo ""
        log_success "Token written. Skipping verification (--no-verify)."
    fi

    # Clean up received file
    rm -f "$json_file" 2>/dev/null || true
}

cmd_provide() {
    local target=""
    local port="$DEFAULT_PORT"
    local force_reauth=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --target)        target="$2"; shift 2 ;;
            --port)          port="$2"; shift 2 ;;
            --force-reauth)  force_reauth=true; shift ;;
            -h|--help)       usage_provide; exit 0 ;;
            *)               log_error "Unknown flag: $1"; usage_provide; exit 1 ;;
        esac
    done

    check_dependencies

    local ip
    ip=$(get_local_ip)
    echo ""
    log_info "This machine's local IP: ${BOLD}${ip}${RESET}"

    # Get or refresh token
    local token=""

    if [[ "$force_reauth" == true ]]; then
        log_info "Force re-auth requested. Running claude auth login..."
        echo ""
        echo "  A browser window will open for authentication."
        echo "  Complete the login, then return here."
        echo ""
        claude auth login
        token=$(extract_token)
    elif [[ -f "$CREDS_FILE" ]]; then
        log_info "Found existing credentials at $CREDS_FILE"
        token=$(extract_token) || true
        if [[ -z "$token" ]]; then
            log_warn "Could not extract token from existing credentials."
            log_info "Running claude auth login..."
            claude auth login
            token=$(extract_token)
        fi
    else
        log_info "No credentials found. Running claude auth login..."
        echo ""
        echo "  A browser window will open for authentication."
        echo "  Complete the login, then return here."
        echo ""
        claude auth login
        token=$(extract_token)
    fi

    if [[ -z "$token" ]]; then
        log_error "Failed to obtain a token. Aborting."
        exit 1
    fi

    log_success "Token extracted: ${token:0:20}..."

    # Package as JSON
    local payload tmpf
    tmpf=$(mktmpfile)
    payload=$(jq -n \
        --arg token "$token" \
        --arg generated_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        --arg source_host "$(hostname)" \
        '{
            claude_code_oauth_token: $token,
            generated_at: $generated_at,
            source_host: $source_host
        }')
    echo "$payload" > "$tmpf"
    # Rename to .json for LocalSend
    local json_tmpf="${tmpf}.json"
    mv "$tmpf" "$json_tmpf"
    TMPFILES+=("$json_tmpf")

    # Discover or prompt for target
    if [[ -z "$target" ]]; then
        echo ""
        target=$(select_device "$port")
    fi

    echo ""
    log_info "Sending token to ${BOLD}${target}:${port}${RESET} via LocalSend..."

    if do_localsend_send "$port" "$target" "$json_tmpf"; then
        echo ""
        log_success "Token sent successfully!"
        log_info "On the target machine, the token should now be received and applied."
    else
        log_error "LocalSend send failed."
        log_error "Make sure the target machine is running: cc-auth-bridge listen --port $port"
        exit 1
    fi
}

# --- Usage / Help ---

usage() {
    cat <<EOF
${BOLD}cc-auth-bridge${RESET} v${VERSION}
Beam Claude Code OAuth tokens to headless machines via LocalSend.

${BOLD}USAGE${RESET}
    cc-auth-bridge [options] [subcommand]

${BOLD}SUBCOMMANDS${RESET}
    listen      (default) Receive a token via LocalSend
    provide     Send a token via LocalSend

${BOLD}OPTIONS${RESET}
    -h, --help      Show this help message
    -v, --version   Print version

Run '${BOLD}cc-auth-bridge <subcommand> --help${RESET}' for subcommand-specific options.

${BOLD}QUICK START${RESET}
    On the headless machine:
        cc-auth-bridge listen

    On the authenticated machine:
        cc-auth-bridge provide
EOF
}

usage_listen() {
    cat <<EOF
${BOLD}cc-auth-bridge listen${RESET}
Receive a Claude Code OAuth token via LocalSend.

${BOLD}FLAGS${RESET}
    --port PORT     LocalSend port (default: $DEFAULT_PORT)
    --no-verify     Skip post-transfer auth verification
    --dry-run       Print what would be done without writing anything
    -h, --help      Show this help
EOF
}

usage_provide() {
    cat <<EOF
${BOLD}cc-auth-bridge provide${RESET}
Send a Claude Code OAuth token via LocalSend.

${BOLD}FLAGS${RESET}
    --target IP       Target machine IP (auto-discovered if not given)
    --port PORT       LocalSend port (default: $DEFAULT_PORT)
    --force-reauth    Re-run 'claude auth login' even if credentials exist
    -h, --help        Show this help
EOF
}

# --- Main ---

main() {
    local cmd=""

    # Parse top-level args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            listen|provide)
                cmd="$1"; shift; break ;;
            -h|--help)
                usage; exit 0 ;;
            -v|--version)
                echo "cc-auth-bridge v${VERSION}"; exit 0 ;;
            -*)
                log_error "Unknown option: $1"; usage; exit 1 ;;
            *)
                log_error "Unknown command: $1"; usage; exit 1 ;;
        esac
    done

    # Default to listen
    if [[ -z "$cmd" ]]; then
        cmd="listen"
    fi

    case "$cmd" in
        listen)  cmd_listen "$@" ;;
        provide) cmd_provide "$@" ;;
    esac
}

main "$@"
